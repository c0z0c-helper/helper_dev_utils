# .env.test
# =========
# pytest 테스트용 환경변수 설정
# 
# 이 파일은 conftest.py에서 자동으로 로드됩니다.
# 테스트 실행 시 MY_CACHE_LOCAL과 MY_DRIVER_PATH를 임시 디렉토리로 설정합니다.

# Windows 임시 디렉토리 (시스템 temp 사용)
MY_CACHE_LOCAL=./Temp/helper_dev_utils_test_cache
MY_DRIVER_PATH=./Temp/helper_dev_utils_test_driver

# Linux/macOS 예시
# MY_CACHE_LOCAL=/tmp/helper_dev_utils_test_cache
# MY_DRIVER_PATH=/tmp/helper_dev_utils_test_driver
